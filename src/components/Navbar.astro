---
const navLinks = [
  { name: "About", href: "#about" },
  { name: "Skills", href: "#skills" },
  { name: "Experience", href: "#experience" },
  { name: "Projects", href: "#projects" },
  { name: "Education", href: "#education" }
];
---

<header class="sticky top-0 z-50 w-full border-b border-border bg-background/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-2 font-mono text-sm font-semibold tracking-tight text-text">
      <span class="flex h-7 w-7 items-center justify-center rounded-md bg-gradient-to-br from-primary to-secondary text-xs font-bold text-white">AC</span>
      <span class="hidden sm:inline">arun.choudhary()</span>
    </a>

    <!-- Nav Links (Desktop) -->
    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a 
          href={link.href} 
          class="rounded-full px-3 py-1.5 text-sm font-medium text-text-secondary transition-colors hover:bg-surface-light hover:text-text"
        >
          {link.name}
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <a 
        href="#contact" 
        class="hidden sm:inline-flex items-center justify-center rounded-full bg-gradient-to-r from-primary to-secondary px-5 py-2 text-xs font-semibold text-white shadow-lg shadow-primary/25 transition-all hover:shadow-primary/40 hover:scale-[1.02] active:scale-[0.98]"
      >
        Contact Me
      </a>
      
      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="flex md:hidden rounded-md p-2 text-text-secondary hover:bg-surface-light hover:text-text focus:outline-none focus:ring-2 focus:ring-primary/50" aria-label="Toggle menu">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden border-b border-border bg-background/95 backdrop-blur-md px-6 py-4 md:hidden">
    <nav class="flex flex-col gap-3">
      {navLinks.map((link) => (
        <a 
          href={link.href} 
          class="mobile-link text-base font-medium text-text-secondary py-2 hover:text-text transition-colors"
        >
          {link.name}
        </a>
      ))}
      <a 
        href="#contact" 
        class="mobile-link mt-2 inline-flex items-center justify-center rounded-full bg-gradient-to-r from-primary to-secondary py-2.5 text-sm font-semibold text-white"
      >
        Contact Me
      </a>
    </nav>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    // Close menu when a link is clicked
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });
  }
</script>
