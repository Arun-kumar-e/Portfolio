---
interface Props {
  class?: string;
  hoverable?: boolean;
}

const { class: className = '', hoverable = true } = Astro.props;
---

<div class={`rounded-lg border border-border bg-surface/60 backdrop-blur-sm p-6 shadow-level2 transition-all duration-300 ${hoverable ? 'hover:border-primary/30 hover:shadow-glow-purple glow-card-hover' : ''} ${className}`}>
  <slot />
</div>
