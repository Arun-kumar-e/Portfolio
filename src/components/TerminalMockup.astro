---
interface OutputLine {
  text: string;
  type?: 'command' | 'success' | 'info' | 'text' | 'error';
}

interface Props {
  title: string;
  lines: OutputLine[];
}

const { title, lines } = Astro.props;
---

<div class="w-full overflow-hidden rounded-lg border border-border bg-[#0d1117] shadow-level4">
  <!-- Terminal Title Bar -->
  <div class="flex items-center justify-between bg-[#161b22] px-4 py-3 border-b border-border select-none">
    <div class="flex items-center gap-2">
      <!-- Terminal dots -->
      <span class="h-3 w-3 rounded-full bg-[#ff5f56] block"></span>
      <span class="h-3 w-3 rounded-full bg-[#ffbd2e] block"></span>
      <span class="h-3 w-3 rounded-full bg-[#27c93f] block"></span>
    </div>
    <span class="font-mono text-xs font-medium text-text-muted tracking-normal">{title}</span>
    <div class="w-10"></div> <!-- spacing balancer -->
  </div>

  <!-- Terminal Content -->
  <div class="p-5 font-mono text-[13px] leading-relaxed text-[#e6edf3] select-text overflow-x-auto">
    <pre class="m-0 space-y-1 bg-transparent border-0 p-0 text-left rounded-none font-mono filter-none select-text whitespace-pre">
      {lines.map((line) => {
        if (line.type === 'command') {
          return (
            <div class="text-[#f0f6fc] font-semibold">
              <span class="text-[#79c0ff] mr-2">$</span>{line.text}
            </div>
          );
        } else if (line.type === 'success') {
          return (
            <div class="text-[#3fb950]">{line.text}</div>
          );
        } else if (line.type === 'info') {
          return (
            <div class="text-[#d2a8ff]">{line.text}</div>
          );
        } else if (line.type === 'error') {
          return (
            <div class="text-[#f85149]">{line.text}</div>
          );
        } else {
          return (
            <div class="text-[#8b949e]">{line.text}</div>
          );
        }
      })}
    </pre>
  </div>
</div>
