---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Card from '../components/Card.astro';
import TerminalMockup from '../components/TerminalMockup.astro';
import avatarImg from '../assets/avatar.png';

interface OutputLine {
  text: string;
  type?: 'command' | 'success' | 'info' | 'text' | 'error';
}

// Projects terminal commands mockups data
const vehicleRentalTerminalLines: OutputLine[] = [
  { text: 'java -jar vehicle-rental.jar', type: 'command' },
  { text: '--- VEHICLE RENTAL MANAGEMENT SYSTEM ---', type: 'info' },
  { text: 'Loading persisted database file: fleet_data.dat... OK (15 vehicles loaded)', type: 'text' },
  { text: 'Loading customer records... OK (8 active customers)', type: 'text' },
  { text: '\nMenu Options:\n  [1] Book a Vehicle\n  [2] Return a Vehicle\n  [3] Manage Customers\n  [4] Exit', type: 'text' },
  { text: '\nSelection: 1', type: 'command' },
  { text: 'Available Fleet:', type: 'text' },
  { text: '  - [V102] Tesla Model Y (Electric SUV) - $80/day (Status: AVAILABLE)', type: 'success' },
  { text: '  - [V105] Ford Mustang GT (Sports)     - $120/day (Status: AVAILABLE)', type: 'success' },
  { text: '  - [V108] Honda Civic Sedan (Economy)  - $45/day (Status: AVAILABLE)', type: 'success' },
  { text: '\nEnter Vehicle ID to Rent: V102', type: 'command' },
  { text: 'Enter Customer Email: arundatika2002@gmail.com', type: 'command' },
  { text: '\nProcessing booking...', type: 'text' },
  { text: 'SUCCESS: Booking confirmed for Arun Choudhary. Tesla Model Y rented.', type: 'success' },
  { text: 'Invoice generated: INV-2026-0089.txt. Database saved to file.', type: 'success' }
];

const hotelManagementTerminalLines: OutputLine[] = [
  { text: 'java -jar hotel-mgmt.jar', type: 'command' },
  { text: 'Initializing Hotel Booking Engine v2.1.0...', type: 'info' },
  { text: 'Connecting Room Registry (HashMap)... OK (50 rooms initialized)', type: 'text' },
  { text: 'Connecting Billing Registry (TreeMap)... OK', type: 'text' },
  { text: '\n> Action: check-in --guest="Jane Doe" --room=304 --type=Deluxe', type: 'command' },
  { text: 'Checking room availability... Room 304 is vacant.', type: 'text' },
  { text: 'SUCCESS: Guest Jane Doe checked in to Room 304 (Deluxe). Room marked OCCUPIED.', type: 'success' },
  { text: '\n> Action: checkout --room=304', type: 'command' },
  { text: 'Retrieving room charge from Collections...', type: 'text' },
  { text: 'Calculating bill: 3 nights @ $120.00/night = $360.00', type: 'text' },
  { text: '----------------------------------------', type: 'text' },
  { text: '  Room 304 Invoice: Jane Doe', type: 'info' },
  { text: '  Base Charge:   $360.00', type: 'text' },
  { text: '  Tax (15%):     $54.00', type: 'text' },
  { text: '  Total Invoice: $414.00', type: 'text' },
  { text: '----------------------------------------', type: 'text' },
  { text: 'Payment status: PAID via Credit Card.', type: 'success' },
  { text: 'Room 304 state reset to VACANT.', type: 'success' }
];

const aegisAcademyTerminalLines: OutputLine[] = [
  { text: 'npm run dev --prefix frontend & mvn spring-boot:run', type: 'command' },
  { text: 'Starting Aegis Academy Application...', type: 'info' },
  { text: 'Spring Boot 3 - JDK 21 - Connecting to Neon PostgreSQL...', type: 'text' },
  { text: 'HikariPool-1 - Connection active. Database state validated.', type: 'success' },
  { text: 'Tomcat initialized on port 8080 (http) with CORS enabled.', type: 'success' },
  { text: 'Vite dev server running at http://localhost:5173', type: 'success' },
  { text: '\n[POST] /api/v1/students - Payload: { rollNumber: "CS-2024-0012", email: "alice@aegis.edu" }', type: 'command' },
  { text: 'db_validation: rollNumber "CS-2024-0012" already exists.', type: 'error' },
  { text: 'api_response: 409 CONFLICT - "Roll number already registered."', type: 'error' },
  { text: 'frontend_state: Inline validation rendered. Form error active.', type: 'info' },
  { text: '\n[GET] /api/v1/analytics/cgpa-breakdown', type: 'command' },
  { text: 'db_query: Average CGPA calculated: 8.42 - Breakdown complete.', type: 'text' },
  { text: 'API response delivered in 45ms. Recharts component updated.', type: 'success' }
];
---

<Layout>
  <!-- Global mesh gradient background -->
  <div class="mesh-gradient-bg"></div>

  <!-- Navbar -->
  <Navbar />

  <main class="mx-auto max-w-6xl px-6 pb-24">
    <!-- Hero Band -->
    <section id="hero" class="py-20 md:py-28 flex flex-col items-center text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1.5 text-xs font-mono font-medium tracking-wide text-primary mb-8">
        <span class="inline-block h-2 w-2 rounded-full bg-secondary animate-pulse"></span>
        OPEN TO WORK — JAVA BACKEND DEVELOPER
      </div>
      
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.1] text-text max-w-4xl mb-6">
        Building robust backend<br />
        <span class="gradient-text">architectures with Java.</span>
      </h1>
      
      <p class="text-lg md:text-xl text-text-secondary max-w-2xl font-normal leading-relaxed mb-10">
        Hi, I'm <strong class="text-text font-semibold">Arun Choudhary</strong>. I write clean, modular, and maintainable backend systems with Core Java, Spring Boot, and SQL, focusing on solving real-world challenges.
      </p>

      <div class="flex flex-col sm:flex-row items-center gap-4">
        <a 
          href="#projects" 
          class="w-full sm:w-auto rounded-full bg-gradient-to-r from-primary to-secondary px-8 py-3.5 text-sm font-semibold text-white shadow-lg shadow-primary/25 transition-all duration-300 hover:shadow-primary/40 hover:scale-[1.02] hover:-translate-y-0.5 text-center"
        >
          View Projects
        </a>
        <a 
          href="#contact" 
          class="w-full sm:w-auto rounded-full border border-border bg-surface/60 backdrop-blur-sm px-8 py-3.5 text-sm font-semibold text-text shadow-level2 transition-all duration-300 hover:border-primary/30 hover:bg-surface-light hover:shadow-glow-purple text-center"
        >
          Contact Me
        </a>
      </div>
    </section>

    <!-- Skills Ribbon -->
    <section class="border-y border-border bg-surface/40 py-6 mb-24 backdrop-blur-sm">
      <div class="flex flex-wrap items-center justify-around gap-6 px-4">
        <div class="flex items-center gap-2 opacity-60 hover:opacity-100 transition-all cursor-default select-none">
          <span class="font-mono text-sm font-bold text-text-secondary">JAVA</span>
        </div>
        <div class="flex items-center gap-2 opacity-60 hover:opacity-100 transition-all cursor-default select-none">
          <span class="font-mono text-sm font-bold text-text-secondary">SPRING BOOT</span>
        </div>
        <div class="flex items-center gap-2 opacity-60 hover:opacity-100 transition-all cursor-default select-none">
          <span class="font-mono text-sm font-bold text-text-secondary">SQL</span>
        </div>
        <div class="flex items-center gap-2 opacity-60 hover:opacity-100 transition-all cursor-default select-none">
          <span class="font-mono text-sm font-bold text-text-secondary">OBJECT ORIENTED DESIGN</span>
        </div>
        <div class="flex items-center gap-2 opacity-60 hover:opacity-100 transition-all cursor-default select-none">
          <span class="font-mono text-sm font-bold text-text-secondary">COLLECTIONS</span>
        </div>
      </div>
    </section>

    <!-- About Me Section -->
    <section id="about" class="scroll-mt-24 mb-24">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center">
        <!-- Left: Text content -->
        <div class="md:col-span-2 space-y-6">
          <div class="font-mono text-xs uppercase tracking-wider text-primary">[ about me ]</div>
          <h2 class="text-3xl font-bold tracking-tight text-text leading-tight">
            Engineering solid foundations for the modern web.
          </h2>
          <p class="text-text-secondary text-base leading-relaxed">
            I am a Computer Science graduate with hands-on practice in Java backend development. My expertise covers Core Java, OOP guidelines, Collections framework, Exception Handling, File I/O, and Spring Boot.
          </p>
          <p class="text-text-secondary text-base leading-relaxed">
            I enjoy designing clean database schemas, crafting modular APIs, and thinking through edge cases. My goal is to build backend systems that are secure, highly maintainable, and run seamlessly under load.
          </p>
          
          <!-- Quick Facts -->
          <div class="grid grid-cols-2 gap-4 pt-4">
            <div class="border-l-2 border-primary pl-4">
              <div class="font-mono text-[11px] text-text-muted uppercase">Location</div>
              <div class="font-semibold text-text text-sm">Jaipur, Rajasthan, India</div>
            </div>
            <div class="border-l-2 border-secondary pl-4">
              <div class="font-mono text-[11px] text-text-muted uppercase">Education</div>
              <div class="font-semibold text-text text-sm">B.Tech in Computer Science</div>
            </div>
          </div>
        </div>

        <!-- Right: Avatar Image -->
        <div class="flex justify-center md:justify-end">
          <div class="relative group">
            <div class="absolute -inset-1 rounded-full bg-gradient-to-r from-primary to-secondary opacity-30 blur-lg transition duration-1000 group-hover:opacity-60 animate-pulse-glow"></div>
            <div class="relative h-64 w-64 overflow-hidden rounded-full border-4 border-surface bg-surface shadow-level4 flex items-center justify-center">
              <img 
                src={avatarImg.src} 
                alt="Arun Choudhary logo" 
                class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.05]"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills Section -->
    <section id="skills" class="scroll-mt-24 mb-24">
      <div class="space-y-6 mb-12">
        <div class="font-mono text-xs uppercase tracking-wider text-primary">[ technical stack ]</div>
        <h2 class="text-3xl font-bold tracking-tight text-text leading-tight">
          Tools, languages, and technologies I work with.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Languages & Core -->
        <Card class="space-y-4">
          <div class="flex items-center justify-between border-b border-border pb-3">
            <h3 class="font-semibold text-text text-base">Languages</h3>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-text-muted">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.25C11.176 10.658 7.69 15.08 3 17.5m6.001-12.217A48.24 48.24 0 0016 5.25M16.29 20.477A21.1 21.1 0 018 15.012" />
            </svg>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="tag-pill">Java (SE)</span>
            <span class="tag-pill">SQL</span>
            <span class="tag-pill">JavaScript (ES6+)</span>
          </div>
        </Card>

        <!-- Backend Development -->
        <Card class="space-y-4 md:col-span-2">
          <div class="flex items-center justify-between border-b border-border pb-3">
            <h3 class="font-semibold text-text text-base">Backend & Architecture</h3>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-text-muted">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5m0-6a3 3 0 013-3m-3 3a3 3 0 100 6M12 3v18M12 3l-1.5 3m1.5-3l1.5 3" />
            </svg>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="tag-pill">Spring Boot</span>
            <span class="tag-pill">Object-Oriented Programming (OOP)</span>
            <span class="tag-pill">Collections Framework</span>
            <span class="tag-pill">Data Structures & Algorithms</span>
            <span class="tag-pill">Exception Handling</span>
            <span class="tag-pill">File Handling (I/O)</span>
            <span class="tag-pill">Database Design</span>
          </div>
        </Card>

        <!-- Frontend -->
        <Card class="space-y-4">
          <div class="flex items-center justify-between border-b border-border pb-3">
            <h3 class="font-semibold text-text text-base">Frontend</h3>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-text-muted">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
            </svg>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="tag-pill">HTML5</span>
            <span class="tag-pill">CSS3 / Responsive Design</span>
          </div>
        </Card>

        <!-- Tools & IDEs -->
        <Card class="space-y-4">
          <div class="flex items-center justify-between border-b border-border pb-3">
            <h3 class="font-semibold text-text text-base">Tools & IDEs</h3>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-text-muted">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766l.002-.001a2.25 2.25 0 012.247 2.977l-.004.013c-.15.462-.4.873-.756 1.209l-3.03 2.496m-2.16-2.16L12.72 15M11.42 15.17l-7.255-7.255A3.11 3.11 0 118.57 3.513L15.82 10.76m0 0l-1.36 1.36m1.36-1.36l-1.5 1.5M9.62 13.04l-1.5-1.5M9.62 13.04L3.75 18.91M3 21l.75-.75" />
            </svg>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="tag-pill">Git</span>
            <span class="tag-pill">GitHub</span>
            <span class="tag-pill">IntelliJ IDEA</span>
            <span class="tag-pill">VS Code</span>
          </div>
        </Card>

        <!-- Currently Learning -->
        <Card class="space-y-4">
          <div class="flex items-center justify-between border-b border-border pb-3">
            <h3 class="font-semibold text-text text-base">Currently Learning</h3>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-text-muted">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
            </svg>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="tag-pill">Spring Boot REST APIs</span>
            <span class="tag-pill">Hibernate / JPA</span>
            <span class="tag-pill">MySQL (Advanced Queries)</span>
            <span class="tag-pill">Docker (Basics)</span>
          </div>
        </Card>
      </div>
    </section>

    <!-- Experience Section -->
    <section id="experience" class="scroll-mt-24 mb-24">
      <div class="space-y-6 mb-12">
        <div class="font-mono text-xs uppercase tracking-wider text-primary">[ career timeline ]</div>
        <h2 class="text-3xl font-bold tracking-tight text-text leading-tight">
          Practical industry experience.
        </h2>
      </div>

      <!-- Experience Items -->
      <div class="space-y-8 relative before:absolute before:inset-0 before:right-auto before:left-[17px] before:w-[1px] before:bg-gradient-to-b before:from-primary/30 before:via-secondary/30 before:to-transparent">
        <!-- Item 1: REGex Software Services -->
        <div class="relative pl-10 group">
          <!-- Timeline dot -->
          <div class="absolute left-3 top-2.5 h-[11px] w-[11px] rounded-full border-2 border-primary bg-background group-hover:bg-primary transition-all duration-300 group-hover:shadow-glow-purple"></div>
          
          <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <!-- Timeline details -->
            <div class="md:col-span-1">
              <span class="font-mono text-xs font-medium text-text-muted uppercase">July 2025 – Feb 2026</span>
              <div class="font-mono text-xs text-text-muted mt-1">Jaipur, India</div>
            </div>
            <!-- Experience details -->
            <Card class="md:col-span-3">
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 mb-4">
                <div>
                  <h3 class="font-semibold text-text text-base">Java Developer Intern</h3>
                  <p class="text-xs text-text-muted font-mono">REGex Software Services</p>
                </div>
                <span class="inline-flex max-w-max items-center rounded-full bg-primary/10 border border-primary/20 px-3 py-1 text-[10px] font-mono text-primary font-medium">Backend Engineering</span>
              </div>
              <ul class="list-disc pl-4 space-y-2 text-sm text-text-secondary">
                <li>Developed Java-based applications using Core Java and OOP principles.</li>
                <li>Built modular and maintainable code bases following SOLID design principles.</li>
                <li>Participated in code reviews, debugging, and integration testing.</li>
                <li>Practiced advanced data structures and algorithmic problem-solving to optimize code paths.</li>
                <li>Leveraged Java Collections Framework for efficient storage and memory management.</li>
              </ul>
            </Card>
          </div>
        </div>

        <!-- Item 2: PRASUNET -->
        <div class="relative pl-10 group">
          <!-- Timeline dot -->
          <div class="absolute left-3 top-2.5 h-[11px] w-[11px] rounded-full border-2 border-secondary bg-background group-hover:bg-secondary transition-all duration-300 group-hover:shadow-glow-cyan"></div>
          
          <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <!-- Timeline details -->
            <div class="md:col-span-1">
              <span class="font-mono text-xs font-medium text-text-muted uppercase">June 2023 – Sept 2023</span>
              <div class="font-mono text-xs text-text-muted mt-1">Jaipur, India</div>
            </div>
            <!-- Experience details -->
            <Card class="md:col-span-3">
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 mb-4">
                <div>
                  <h3 class="font-semibold text-text text-base">Web Development Intern</h3>
                  <p class="text-xs text-text-muted font-mono">PRASUNET Pvt. Ltd.</p>
                </div>
                <span class="inline-flex max-w-max items-center rounded-full bg-secondary/10 border border-secondary/20 px-3 py-1 text-[10px] font-mono text-secondary font-medium">Web Development</span>
              </div>
              <ul class="list-disc pl-4 space-y-2 text-sm text-text-secondary">
                <li>Built responsive web pages using semantic HTML, CSS, and modern JavaScript.</li>
                <li>Improved User Experience (UX) through interactive UI components and smooth transitions.</li>
                <li>Implemented client-side form validations and dynamic data manipulation.</li>
                <li>Collaborated closely with the frontend engineering team to deliver polished web applications.</li>
              </ul>
            </Card>
          </div>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="scroll-mt-24 mb-24">
      <div class="space-y-6 mb-12">
        <div class="font-mono text-xs uppercase tracking-wider text-primary">[ featured works ]</div>
        <h2 class="text-3xl font-bold tracking-tight text-text leading-tight">
          Full-Stack & Backend Software Projects.
        </h2>
      </div>

      <div class="space-y-16">
        <!-- Project 1: Aegis Academy -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
          <div class="lg:col-span-5 space-y-4">
            <span class="font-mono text-[10px] font-semibold text-text-muted uppercase tracking-widest">[ Full-Stack Web App ]</span>
            <h3 class="text-2xl font-bold tracking-tight text-text">Aegis Academy — Student Management Console</h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              A comprehensive student records and administrative management system designed to provide real-time metrics and seamless CRUD workflows. This application acts as a central administrative console, enabling administrators to track student details, analyze grades, and oversee departmental enrollment patterns via an interactive dashboard.
            </p>
            <div class="space-y-4">
              <div class="space-y-1.5">
                <h4 class="font-mono text-xs font-semibold text-text">Key Features:</h4>
                <ul class="list-disc pl-4 space-y-1 text-xs text-text-secondary">
                  <li><strong>Full CRUD Operations:</strong> Complete student profile management including dynamic search, department filtering, and a paginated table.</li>
                  <li><strong>Interactive Visual Analytics:</strong> Dashboard displaying real-time metrics (Total Students, Average CGPA) and departmental distributions using Recharts.</li>
                  <li><strong>Student Detail View:</strong> Dedicated student profiles containing an animated CGPA progress ring and complete academic records.</li>
                  <li><strong>Theme-Responsive UX:</strong> Implemented a full light/dark mode system featuring fluid Framer Motion animations.</li>
                </ul>
              </div>
              
              <div class="space-y-1.5">
                <h4 class="font-mono text-xs font-semibold text-text">Technical Highlights:</h4>
                <ul class="list-disc pl-4 space-y-1 text-xs text-text-secondary">
                  <li><strong>Layered Backend Architecture:</strong> Engineered a modular Spring Boot architecture separating controllers, services, and repositories.</li>
                  <li><strong>Validation & Error Parity:</strong> Client-side validation mirrors server-side Hibernate validator logic, displaying inline errors for 400 and 409 responses.</li>
                  <li><strong>CORS & Environment Management:</strong> Practiced production deployments using a free-tier hosting stack (Render, Vercel, Neon DB) with clean env-variable injections.</li>
                </ul>
              </div>

              <div class="space-y-1.5">
                <h4 class="font-mono text-xs font-semibold text-text">What I'd Improve Next:</h4>
                <ul class="list-disc pl-4 space-y-1 text-xs text-text-secondary">
                  <li><strong>Secure Authentication:</strong> Integrate Spring Security with JWT tokens for role-based access control (Admin vs. Student).</li>
                  <li><strong>Testing Suite:</strong> Implement unit tests with JUnit/Mockito and frontend component testing with Vitest.</li>
                  <li><strong>Real-Time Synchronization:</strong> Use WebSockets for push notifications during student enrollment changes.</li>
                </ul>
              </div>
            </div>
            
            <div class="flex flex-wrap items-center gap-3 pt-4">
              <a 
                href="https://student-management-system-eta-blond.vercel.app" 
                target="_blank" 
                rel="noreferrer" 
                class="rounded-full bg-gradient-to-r from-primary to-secondary px-5 py-2.5 text-xs font-semibold text-white shadow-lg shadow-primary/25 hover:shadow-primary/40 transition-all flex items-center gap-2"
