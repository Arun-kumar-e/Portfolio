<script>
  const copyBtn = document.getElementById('copy-btn');
  const emailText = document.getElementById('email-text');
  const copiedToast = document.getElementById('copied-toast');

  if (copyBtn && emailText && copiedToast) {
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(emailText.textContent || '').then(() => {
        // Show toast
        copiedToast.classList.remove('opacity-0');
        copiedToast.classList.add('opacity-100');

        // Hide toast after 2s
        setTimeout(() => {
          copiedToast.classList.remove('opacity-100');
          copiedToast.classList.add('opacity-0');
        }, 2000);
      }).catch(err => {
        console.error('Failed to copy text: ', err);
      });
    });
  }
</script>
