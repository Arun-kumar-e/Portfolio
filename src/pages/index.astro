---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Card from '../components/Card.astro';
import TerminalMockup from '../components/TerminalMockup.astro';
import avatarImg from '../assets/avatar.png';

interface OutputLine {
  text: string;
  type?: 'command' | 'success' | 'info' | 'text' | 'error';
}

// Projects terminal commands mockups data
const vehicleRentalTerminalLines: OutputLine[] = [
  { text: 'java -jar vehicle-rental.jar', type: 'command' },
  { text: '--- VEHICLE RENTAL MANAGEMENT SYSTEM ---', type: 'info' },
  { text: 'Loading persisted database file: fleet_data.dat... OK (15 vehicles loaded)', type: 'text' },
  { text: 'Loading customer records... OK (8 active customers)', type: 'text' },
  { text: '\nMenu Options:\n  [1] Book a Vehicle\n  [2] Return a Vehicle\n  [3] Manage Customers\n  [4] Exit', type: 'text' },
  { text: '\nSelection: 1', type: 'command' },
  { text: 'Available Fleet:', type: 'text' },
  { text: '  - [V102] Tesla Model Y (Electric SUV) - $80/day (Status: AVAILABLE)', type: 'success' },
  { text: '  - [V105] Ford Mustang GT (Sports)     - $120/day (Status: AVAILABLE)', type: 'success' },
  { text: '  - [V108] Honda Civic Sedan (Economy)  - $45/day (Status: AVAILABLE)', type: 'success' },
  { text: '\nEnter Vehicle ID to Rent: V102', type: 'command' },
  { text: 'Enter Customer Email: arundatika2002@gmail.com', type: 'command' },
  { text: '\nProcessing booking...', type: 'text' },
  { text: 'SUCCESS: Booking confirmed for Arun Choudhary. Tesla Model Y rented.', type: 'success' },
  { text: 'Invoice generated: INV-2026-0089.txt. Database saved to file.', type: 'success' }
];

const hotelManagementTerminalLines: OutputLine[] = [
  { text: 'java -jar hotel-mgmt.jar', type: 'command' },
  { text: 'Initializing Hotel Booking Engine v2.1.0...', type: 'info' },
  { text: 'Connecting Room Registry (HashMap)... OK (50 rooms initialized)', type: 'text' },
  { text: 'Connecting Billing Registry (TreeMap)... OK', type: 'text' },
  { text: '\n> Action: check-in --guest="Jane Doe" --room=304 --type=Deluxe', type: 'command' },
  { text: 'Checking room availability... Room 304 is vacant.', type: 'text' },
  { text: 'SUCCESS: Guest Jane Doe checked in to Room 304 (Deluxe). Room marked OCCUPIED.', type: 'success' },
  { text: '\n> Action: checkout --room=304', type: 'command' },
  { text: 'Retrieving room charge from Collections...', type: 'text' },
  { text: 'Calculating bill: 3 nights @ $120.00/night = $360.00', type: 'text' },
  { text: '----------------------------------------', type: 'text' },
  { text: '  Room 304 Invoice: Jane Doe', type: 'info' },
  { text: '  Base Charge:   $360.00', type: 'text' },
  { text: '  Tax (15%):     $54.00', type: 'text' },
  { text: '  Total Invoice: $414.00', type: 'text' },
  { text: '----------------------------------------', type: 'text' },
  { text: 'Payment status: PAID via Credit Card.', type: 'success' },
  { text: 'Room 304 state reset to VACANT.', type: 'success' }
];
---

<Layout>
  <!-- Global mesh gradient background -->
  <div class="mesh-gradient-bg"></div>

  <!-- Navbar -->
  <Navbar />

  <main class="mx-auto max-w-6xl px-6 pb-24">
    <!-- Hero Band -->
    <section id="hero" class="py-20 md:py-28 flex flex-col items-center text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-3 py-1 text-[11px] font-mono font-medium tracking-tight text-body shadow-level1 mb-6">
        <span class="inline-block h-2 w-2 rounded-full bg-cyan animate-pulse"></span>
        AVAILABLE FOR FULL-TIME ROLES IN INDIA / REMOTE
      </div>
      
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-semibold tracking-[-0.04em] leading-[1.05] text-ink max-w-4xl mb-6">
        Building robust backend architectures with Java.
      </h1>
      
      <p class="text-lg md:text-xl text-body max-w-2xl font-normal leading-relaxed mb-10">
        Hi, I'm <strong class="text-ink font-semibold">Arun Choudhary</strong>. I write clean, modular, and maintainable backend systems with Core Java, Spring Boot, and SQL, focusing on solving real-world challenges.
      </p>

      <div class="flex flex-col sm:flex-row items-center gap-4">
        <a 
          href="#projects" 
          class="w-full sm:w-auto rounded-pill bg-primary px-8 py-3.5 text-sm font-medium text-on-primary shadow-level3 transition-all duration-200 hover:bg-black hover:shadow-level4 hover:scale-[1.01] text-center"
        >
          View Projects
        </a>
        <a 
          href="#contact" 
          class="w-full sm:w-auto rounded-pill border border-hairline bg-canvas px-8 py-3.5 text-sm font-medium text-ink shadow-level2 transition-all duration-200 hover:bg-canvas-soft-2 hover:border-hairline-strong text-center"
        >
          Contact Me
        </a>
      </div>
    </section>

    <!-- Logo/Skills Ribbon -->
    <section class="border-y border-hairline bg-canvas/40 py-6 mb-24 backdrop-blur-sm">
      <div class="flex flex-wrap items-center justify-around gap-6 px-4">
        <div class="flex items-center gap-2 grayscale hover:grayscale-0 transition-all cursor-default select-none">
          <span class="font-mono text-sm font-bold text-ink">JAVA</span>
        </div>
        <div class="flex items-center gap-2 grayscale hover:grayscale-0 transition-all cursor-default select-none">
          <span class="font-mono text-sm font-bold text-ink">SPRING BOOT</span>
        </div>
        <div class="flex items-center gap-2 grayscale hover:grayscale-0 transition-all cursor-default select-none">
          <span class="font-mono text-sm font-bold text-ink">SQL</span>
        </div>
        <div class="flex items-center gap-2 grayscale hover:grayscale-0 transition-all cursor-default select-none">
          <span class="font-mono text-sm font-bold text-ink">OBJECT ORIENTED DESIGN</span>
        </div>
        <div class="flex items-center gap-2 grayscale hover:grayscale-0 transition-all cursor-default select-none">
          <span class="font-mono text-sm font-bold text-ink">COLLECTIONS</span>
        </div>
      </div>
    </section>

    <!-- About Me Section -->
    <section id="about" class="scroll-mt-24 mb-24">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center">
        <!-- Left: Text content -->
        <div class="md:col-span-2 space-y-6">
          <div class="font-mono text-xs uppercase tracking-wider text-mute">[ about me ]</div>
          <h2 class="text-3xl font-semibold tracking-[-0.03em] text-ink leading-tight">
            Engineering solid foundations for the modern web.
          </h2>
          <p class="text-body text-base leading-relaxed">
            I am a Computer Science graduate with hands-on practice in Java backend development. My expertise covers Core Java, OOP guidelines, Collections framework, Exception Handling, File I/O, and Spring Boot.
          </p>
          <p class="text-body text-base leading-relaxed">
            I enjoy designing clean database schemas, crafting modular APIs, and thinking through edge cases. My goal is to build backend systems that are secure, highly maintainable, and run seamlessly under load.
          </p>
          
          <!-- Quick Facts -->
          <div class="grid grid-cols-2 gap-4 pt-4">
            <div class="border-l-2 border-primary pl-4">
              <div class="font-mono text-[11px] text-mute uppercase">Location</div>
              <div class="font-semibold text-ink text-sm">Jaipur, Rajasthan, India</div>
            </div>
            <div class="border-l-2 border-primary pl-4">
              <div class="font-mono text-[11px] text-mute uppercase">Education</div>
              <div class="font-semibold text-ink text-sm">B.Tech in Computer Science</div>
            </div>
          </div>
        </div>

        <!-- Right: Avatar Image Mockup -->
        <div class="flex justify-center md:justify-end">
          <div class="relative group">
            <div class="absolute -inset-0.5 rounded-full bg-gradient-to-r from-violet to-cyan opacity-30 blur-md transition duration-1000 group-hover:opacity-60"></div>
            <div class="relative h-64 w-64 overflow-hidden rounded-full border-4 border-canvas bg-primary shadow-level4 flex items-center justify-center">
              <img 
                src={avatarImg.src} 
                alt="Arun Choudhary logo" 
                class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.05]"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills Section -->
    <section id="skills" class="scroll-mt-24 mb-24">
      <div class="space-y-6 mb-12">
        <div class="font-mono text-xs uppercase tracking-wider text-mute">[ technical stack ]</div>
        <h2 class="text-3xl font-semibold tracking-[-0.03em] text-ink leading-tight">
          Tools, languages, and technologies I work with.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Languages & Core -->
        <Card class="space-y-4 glow-card-hover">
          <div class="flex items-center justify-between border-b border-hairline pb-3">
            <h3 class="font-semibold text-ink text-base">Languages</h3>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-mute">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.25C11.176 10.658 7.69 15.08 3 17.5m6.001-12.217A48.24 48.24 0 0016 5.25M16.29 20.477A21.1 21.1 0 018 15.012" />
            </svg>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">Java (SE)</span>
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">SQL</span>
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">JavaScript (ES6+)</span>
          </div>
        </Card>

        <!-- Backend Development -->
        <Card class="space-y-4 glow-card-hover md:col-span-2">
          <div class="flex items-center justify-between border-b border-hairline pb-3">
            <h3 class="font-semibold text-ink text-base">Backend & Architecture</h3>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-mute">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5m0-6a3 3 0 013-3m-3 3a3 3 0 100 6M12 3v18M12 3l-1.5 3m1.5-3l1.5 3" />
            </svg>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">Spring Boot</span>
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">Object-Oriented Programming (OOP)</span>
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">Collections Framework</span>
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">Data Structures & Algorithms</span>
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">Exception Handling</span>
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">File Handling (I/O)</span>
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">Database Design</span>
          </div>
        </Card>

        <!-- Frontend, Tools & Soft Skills -->
        <Card class="space-y-4 glow-card-hover">
          <div class="flex items-center justify-between border-b border-hairline pb-3">
            <h3 class="font-semibold text-ink text-base">Frontend</h3>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-mute">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
            </svg>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">HTML5</span>
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">CSS3 / Responsive Design</span>
          </div>
        </Card>

        <Card class="space-y-4 glow-card-hover">
          <div class="flex items-center justify-between border-b border-hairline pb-3">
            <h3 class="font-semibold text-ink text-base">Tools & IDEs</h3>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-mute">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766l.002-.001a2.25 2.25 0 012.247 2.977l-.004.013c-.15.462-.4.873-.756 1.209l-3.03 2.496m-2.16-2.16L12.72 15M11.42 15.17l-7.255-7.255A3.11 3.11 0 118.57 3.513L15.82 10.76m0 0l-1.36 1.36m1.36-1.36l-1.5 1.5M9.62 13.04l-1.5-1.5M9.62 13.04L3.75 18.91M3 21l.75-.75" />
            </svg>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">Git</span>
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">GitHub</span>
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">IntelliJ IDEA</span>
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">VS Code</span>
          </div>
        </Card>

        <Card class="space-y-4 glow-card-hover">
          <div class="flex items-center justify-between border-b border-hairline pb-3">
            <h3 class="font-semibold text-ink text-base">Soft Skills</h3>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-mute">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.97 5.97 0 00-.75-2.906m-13.82 2.9A9.09 9.09 0 016 18.72a3 3 0 00-4.681-2.72 8.986 8.986 0 003.74.477m.94 3.197a11.966 11.966 0 01-.037-.666 5.962 5.962 0 011-2.906m1-5.188a3 3 0 100-6 3 3 0 000 6zm12 0a3 3 0 100-6 3 3 0 000 6z" />
            </svg>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">Problem Solving</span>
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">Analytical Thinking</span>
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">Team Collaboration</span>
            <span class="rounded-full bg-canvas-soft border border-hairline px-3 py-1 text-xs font-mono text-body font-medium">Clear Communication</span>
          </div>
        </Card>
      </div>
    </section>

    <!-- Experience Section -->
    <section id="experience" class="scroll-mt-24 mb-24">
      <div class="space-y-6 mb-12">
        <div class="font-mono text-xs uppercase tracking-wider text-mute">[ career timeline ]</div>
        <h2 class="text-3xl font-semibold tracking-[-0.03em] text-ink leading-tight">
          Practical industry experience.
        </h2>
      </div>

      <!-- Experience Items -->
      <div class="space-y-8 relative before:absolute before:inset-0 before:right-auto before:left-[17px] before:w-[1px] before:bg-hairline">
        <!-- Item 1: REGex Software Services -->
        <div class="relative pl-10 group">
          <!-- Timeline dot -->
          <div class="absolute left-3 top-2.5 h-[11px] w-[11px] rounded-full border border-hairline-strong bg-canvas group-hover:bg-primary transition-all duration-300"></div>
          
          <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <!-- Timeline details -->
            <div class="md:col-span-1">
              <span class="font-mono text-xs font-medium text-mute uppercase">Nov 2023 – Present</span>
              <div class="font-mono text-xs text-mute mt-1">Jaipur, India</div>
            </div>
            <!-- Experience details -->
            <Card class="md:col-span-3 glow-card-hover">
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 mb-4">
                <div>
                  <h3 class="font-semibold text-ink text-base">Java Developer Intern</h3>
                  <p class="text-xs text-mute font-mono">REGex Software Services</p>
                </div>
                <span class="inline-flex max-w-max items-center rounded-sm bg-violet-soft/20 border border-violet-soft/30 px-2 py-0.5 text-[10px] font-mono text-violet font-medium">Backend Engineering</span>
              </div>
              <ul class="list-disc pl-4 space-y-2 text-sm text-body">
                <li>Developed Java-based applications using Core Java and OOP principles.</li>
                <li>Built modular and maintainable code bases following SOLID design principles.</li>
                <li>Participated in code reviews, debugging, and integration testing.</li>
                <li>Practiced advanced data structures and algorithmic problem-solving to optimize code paths.</li>
                <li>Leveraged Java Collections Framework for efficient storage and memory management.</li>
              </ul>
            </Card>
          </div>
        </div>

        <!-- Item 2: PRASUNET -->
        <div class="relative pl-10 group">
          <!-- Timeline dot -->
          <div class="absolute left-3 top-2.5 h-[11px] w-[11px] rounded-full border border-hairline-strong bg-canvas group-hover:bg-primary transition-all duration-300"></div>
          
          <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <!-- Timeline details -->
            <div class="md:col-span-1">
              <span class="font-mono text-xs font-medium text-mute uppercase">June 2023 – Sept 2023</span>
              <div class="font-mono text-xs text-mute mt-1">Jaipur, India</div>
            </div>
            <!-- Experience details -->
            <Card class="md:col-span-3 glow-card-hover">
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 mb-4">
                <div>
                  <h3 class="font-semibold text-ink text-base">Web Development Intern</h3>
                  <p class="text-xs text-mute font-mono">PRASUNET Pvt. Ltd.</p>
                </div>
                <span class="inline-flex max-w-max items-center rounded-sm bg-cyan-soft/20 border border-cyan-soft/30 px-2 py-0.5 text-[10px] font-mono text-cyan-deep font-medium">Web Development</span>
              </div>
              <ul class="list-disc pl-4 space-y-2 text-sm text-body">
                <li>Built responsive web pages using semantic HTML, CSS, and modern JavaScript.</li>
                <li>Improved User Experience (UX) through interactive UI components and smooth transitions.</li>
                <li>Implemented client-side form validations and dynamic data manipulation.</li>
                <li>Collaborated closely with the frontend engineering team to deliver polished web applications.</li>
              </ul>
            </Card>
          </div>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="scroll-mt-24 mb-24">
      <div class="space-y-6 mb-12">
        <div class="font-mono text-xs uppercase tracking-wider text-mute">[ featured works ]</div>
        <h2 class="text-3xl font-semibold tracking-[-0.03em] text-ink leading-tight">
          Java & Object-Oriented Software Projects.
        </h2>
      </div>

      <div class="space-y-16">
        <!-- Project 1: Vehicle Rental -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
          <div class="lg:col-span-5 space-y-4">
            <span class="font-mono text-[10px] font-semibold text-mute uppercase tracking-widest">[ Java Core & File I/O ]</span>
            <h3 class="text-2xl font-semibold tracking-[-0.02em] text-ink">Vehicle Rental System</h3>
            <p class="text-sm text-body leading-relaxed">
              A robust, console-based application designed to manage automobile bookings. Built following pure Object-Oriented Programming (OOP) paradigms with a structured modular architecture, this project offers persistent file-based data storage for fleet and client tracking.
            </p>
            <div class="space-y-2.5">
              <h4 class="font-mono text-xs font-semibold text-ink">Key Features:</h4>
              <ul class="list-disc pl-4 space-y-1.5 text-xs text-body">
                <li>Modular vehicle hierarchy (Sedans, Trucks, SUVs) utilizing inheritance.</li>
                <li>Persistent storage system maintaining fleet and booking registers across runtime sessions.</li>
                <li>Dynamic invoice formatting saved to external local files.</li>
                <li>Input sanitization and custom exception handling.</li>
              </ul>
            </div>
            <div class="flex items-center gap-3 pt-4">
              <a 
                href="https://github.com/Arun-kumar-e" 
                target="_blank" 
                rel="noreferrer" 
                class="rounded-sm bg-primary px-4 py-2 text-xs font-mono text-on-primary font-semibold hover:bg-black flex items-center gap-1.5"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                GitHub Repository
              </a>
            </div>
          </div>
          <div class="lg:col-span-7">
            <!-- Terminal view -->
            <TerminalMockup title="bash - arun@java: ~/VehicleRentalSystem" lines={vehicleRentalTerminalLines} />
          </div>
        </div>

        <hr class="border-hairline" />

        <!-- Project 2: Hotel Management -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
          <div class="lg:col-span-5 space-y-4">
